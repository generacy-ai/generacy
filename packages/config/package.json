{
  "name": "@generacy-ai/config",
  "version": "0.1.0",
  "description": "Centralized workspace configuration for Generacy monorepo",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
