{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://generacy.ai/schemas/workflow.schema.json",
  "title": "Generacy Workflow",
  "description": "Schema for Generacy workflow YAML files",
  "type": "object",
  "required": ["name", "version"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Unique name for the workflow",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$"
    },
    "version": {
      "type": "string",
      "description": "Semantic version of the workflow",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "examples": ["1.0.0", "2.1.3"]
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of the workflow",
      "maxLength": 1024
    },
    "triggers": {
      "type": "array",
      "description": "Events that can start this workflow",
      "items": {
        "$ref": "#/definitions/trigger"
      }
    },
    "env": {
      "type": "object",
      "description": "Environment variables available to all phases",
      "additionalProperties": {
        "oneOf": [
          { "type": "string" },
          { "$ref": "#/definitions/secretRef" },
          { "$ref": "#/definitions/envRef" }
        ]
      }
    },
    "phases": {
      "type": "array",
      "description": "Ordered list of phases to execute",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/phase"
      }
    },
    "on_error": {
      "$ref": "#/definitions/errorHandler",
      "description": "Global error handling configuration"
    },
    "timeout": {
      "type": "string",
      "description": "Maximum execution time for the entire workflow",
      "pattern": "^\\d+[smh]$",
      "examples": ["30m", "2h", "3600s"]
    },
    "metadata": {
      "type": "object",
      "description": "Custom metadata for the workflow",
      "additionalProperties": true
    }
  },
  "definitions": {
    "trigger": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "description": "Type of trigger",
          "enum": ["manual", "schedule", "webhook", "issue", "pull_request", "push"]
        },
        "config": {
          "type": "object",
          "description": "Trigger-specific configuration",
          "additionalProperties": true
        },
        "filters": {
          "type": "object",
          "description": "Conditions that must be met for the trigger to fire",
          "properties": {
            "branches": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Branch patterns to match"
            },
            "paths": {
              "type": "array",
              "items": { "type": "string" },
              "description": "File path patterns to match"
            },
            "labels": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Issue/PR labels to match"
            }
          },
          "additionalProperties": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "schedule" } }
          },
          "then": {
            "properties": {
              "config": {
                "type": "object",
                "required": ["cron"],
                "properties": {
                  "cron": {
                    "type": "string",
                    "description": "Cron expression for scheduling",
                    "pattern": "^(@(annually|yearly|monthly|weekly|daily|hourly))|((\\*|([0-9]|1[0-9]|2[0-9]|3[0-9]|4[0-9]|5[0-9])|\\*\\/([0-9]|1[0-9]|2[0-9]|3[0-9]|4[0-9]|5[0-9])) (\\*|([0-9]|1[0-9]|2[0-3])|\\*\\/([0-9]|1[0-9]|2[0-3])) (\\*|([1-9]|1[0-9]|2[0-9]|3[0-1])|\\*\\/([1-9]|1[0-9]|2[0-9]|3[0-1])) (\\*|([1-9]|1[0-2])|\\*\\/([1-9]|1[0-2])) (\\*|([0-6])|\\*\\/([0-6])))$"
                  },
                  "timezone": {
                    "type": "string",
                    "description": "Timezone for the schedule",
                    "examples": ["UTC", "America/New_York", "Europe/London"]
                  }
                }
              }
            }
          }
        }
      ]
    },
    "phase": {
      "type": "object",
      "required": ["name", "steps"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique name for the phase within this workflow",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of the phase",
          "maxLength": 512
        },
        "condition": {
          "$ref": "#/definitions/condition",
          "description": "Condition that must be true to execute this phase"
        },
        "env": {
          "type": "object",
          "description": "Environment variables for this phase (merged with workflow env)",
          "additionalProperties": {
            "oneOf": [
              { "type": "string" },
              { "$ref": "#/definitions/secretRef" },
              { "$ref": "#/definitions/envRef" }
            ]
          }
        },
        "steps": {
          "type": "array",
          "description": "Ordered list of steps to execute in this phase",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/step"
          }
        },
        "on_error": {
          "$ref": "#/definitions/errorHandler",
          "description": "Error handling for this phase"
        },
        "timeout": {
          "type": "string",
          "description": "Maximum execution time for this phase",
          "pattern": "^\\d+[smh]$"
        },
        "retry": {
          "$ref": "#/definitions/retryConfig",
          "description": "Retry configuration for the entire phase"
        }
      }
    },
    "step": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique name for the step within this phase",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of the step",
          "maxLength": 512
        },
        "uses": {
          "type": "string",
          "description": "Action or agent to use for this step",
          "examples": ["agent/claude-code", "action/shell", "action/http"]
        },
        "with": {
          "type": "object",
          "description": "Input parameters for the action/agent",
          "additionalProperties": true
        },
        "run": {
          "type": "string",
          "description": "Shell command to run (alternative to uses)",
          "minLength": 1
        },
        "condition": {
          "$ref": "#/definitions/condition",
          "description": "Condition that must be true to execute this step"
        },
        "env": {
          "type": "object",
          "description": "Environment variables for this step",
          "additionalProperties": {
            "oneOf": [
              { "type": "string" },
              { "$ref": "#/definitions/secretRef" },
              { "$ref": "#/definitions/envRef" }
            ]
          }
        },
        "outputs": {
          "type": "object",
          "description": "Named outputs from this step",
          "additionalProperties": {
            "type": "string"
          }
        },
        "timeout": {
          "type": "string",
          "description": "Maximum execution time for this step",
          "pattern": "^\\d+[smh]$"
        },
        "retry": {
          "$ref": "#/definitions/retryConfig",
          "description": "Retry configuration for this step"
        },
        "continue_on_error": {
          "type": "boolean",
          "description": "Whether to continue execution if this step fails",
          "default": false
        }
      },
      "oneOf": [
        { "required": ["uses"] },
        { "required": ["run"] }
      ]
    },
    "condition": {
      "oneOf": [
        {
          "type": "string",
          "description": "Expression that evaluates to true/false",
          "examples": [
            "${{ always() }}",
            "${{ failure() }}",
            "${{ success() }}",
            "${{ env.DEPLOY_ENV == 'production' }}"
          ]
        },
        {
          "type": "object",
          "properties": {
            "if": {
              "type": "string",
              "description": "Expression to evaluate"
            }
          },
          "required": ["if"],
          "additionalProperties": false
        }
      ]
    },
    "errorHandler": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "strategy": {
          "type": "string",
          "description": "How to handle errors",
          "enum": ["fail", "continue", "retry"],
          "default": "fail"
        },
        "notify": {
          "type": "array",
          "description": "Notification channels to alert on error",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["slack", "email", "webhook"]
              },
              "config": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "required": ["type"]
          }
        },
        "cleanup": {
          "type": "array",
          "description": "Steps to run for cleanup on error",
          "items": {
            "$ref": "#/definitions/step"
          }
        }
      }
    },
    "retryConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_attempts": {
          "type": "integer",
          "description": "Maximum number of retry attempts",
          "minimum": 1,
          "maximum": 10,
          "default": 3
        },
        "delay": {
          "type": "string",
          "description": "Delay between retry attempts",
          "pattern": "^\\d+[smh]$",
          "default": "10s"
        },
        "backoff": {
          "type": "string",
          "description": "Backoff strategy",
          "enum": ["constant", "linear", "exponential"],
          "default": "exponential"
        },
        "max_delay": {
          "type": "string",
          "description": "Maximum delay between retries",
          "pattern": "^\\d+[smh]$"
        }
      }
    },
    "secretRef": {
      "type": "object",
      "description": "Reference to a secret value",
      "required": ["secret"],
      "additionalProperties": false,
      "properties": {
        "secret": {
          "type": "string",
          "description": "Name of the secret",
          "pattern": "^[A-Z][A-Z0-9_]*$"
        }
      }
    },
    "envRef": {
      "type": "object",
      "description": "Reference to an environment variable",
      "required": ["env"],
      "additionalProperties": false,
      "properties": {
        "env": {
          "type": "string",
          "description": "Name of the environment variable"
        },
        "default": {
          "type": "string",
          "description": "Default value if the variable is not set"
        }
      }
    }
  }
}
