{
  "name": "@generacy-ai/generacy-plugin-jira",
  "version": "0.1.0",
  "description": "Atlassian Jira integration plugin for Generacy",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "generacy",
    "jira",
    "atlassian",
    "plugin",
    "issues",
    "automation"
  ],
  "author": "Generacy AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/generacy-ai/generacy.git",
    "directory": "packages/jira"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@generacy-ai/latency": "workspace:*",
    "@generacy-ai/latency-plugin-issue-tracker": "workspace:*",
    "jira.js": "^4.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
