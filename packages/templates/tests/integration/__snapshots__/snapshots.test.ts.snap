exports[`Snapshot: Edge Cases > should match snapshot for config.yaml with orchestrator section 1`] = `
"# .generacy/config.yaml
# Generated: 2026-02-24T16:45:30.123Z
# Schema version: 1.0.0
# Generated by: generacy-cloud
#
# This file defines your Generacy project configuration.
# Learn more: https://docs.generacy.ai/config

# ============================================================================
# Project Metadata
# ============================================================================

project:
  # Unique project identifier
  id: "proj_xyz789def"

  # Human-readable project name
  name: "Acme Platform"

# ============================================================================
# Repository Configuration
# ============================================================================

repos:
  # Primary repository (receives onboarding PR)
  primary: "github.com/acme-corp/platform-orchestrator"

  # Development repositories (Generacy can create PRs here)
  dev:
    - "github.com/acme-corp/api-service"
    - "github.com/acme-corp/frontend-app"
    - "github.com/acme-corp/worker-service"

  # Clone-only repositories (read-only access, no PRs created)
  clone:
    - "github.com/acme-corp/shared-lib"
    - "github.com/acme-corp/proto-definitions"

# ============================================================================
# Default Settings
# ============================================================================

defaults:
  # Default AI agent to use for tasks
  agent: "claude-code"

  # Default base branch for pull requests
  baseBranch: "develop"

# ============================================================================
# Orchestrator Configuration (Multi-Repo Projects)
# ============================================================================

orchestrator:
  # How often the orchestrator checks for new tasks (milliseconds)
  pollIntervalMs: 5000

  # Number of parallel worker containers to spawn
  workerCount: 2

# ============================================================================
# Cluster Configuration
# ============================================================================

cluster:
  # Cluster variant determines the Docker topology for the dev container
  # - standard: Docker-outside-of-Docker (DooD) — for apps that don't run containers
  # - microservices: Docker-in-Docker (DinD) — each worker can run isolated container stacks
  variant: "standard"
"
`;

exports[`Snapshot: Edge Cases > should match snapshot for devcontainer.json with docker-compose 1`] = `
"{
  "name": "Acme Platform",
  "dockerComposeFile": "docker-compose.yml",
  "service": "orchestrator",
  "workspaceFolder": "/workspaces/platform-orchestrator",
  "customizations": {
    "vscode": {
      "extensions": [
        "generacy-ai.agency",
        "generacy-ai.generacy"
      ]
    }
  }
}
"
`;

exports[`Snapshot: Edge Cases > should match snapshot for docker-compose.yml cluster services 1`] = `
"# docker-compose.yml
# Generated: 2026-02-24T16:45:30.123Z
# Schema version: 1.0.0
# Generated by: generacy-cloud
#
# Standard cluster (DooD) for Acme Platform
# Orchestrator + Workers + Redis — Docker-outside-of-Docker

services:
  # ==========================================================================
  # Redis - Message queue for orchestrator/worker communication
  # ==========================================================================
  redis:
    image: redis:7-alpine
    command: redis-server --appendonly no --save ""
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 5
      start_period: 5s
    volumes:
      - redis-data:/data
    networks:
      - generacy
    restart: unless-stopped

  # ==========================================================================
  # Orchestrator - Main development container
  # ==========================================================================
  orchestrator:
    build:
      context: .
      dockerfile: Dockerfile
    entrypoint: /usr/local/share/scripts/entrypoint-orchestrator.sh
    user: node
    restart: unless-stopped
    stop_grace_period: 30s

    ports:
      - "\${ORCHESTRATOR_PORT:-3100}:\${ORCHESTRATOR_PORT:-3100}"

    env_file:
      - .env

    environment:
      - ROLE=orchestrator
      - REPO_URL=\${REPO_URL}
      - REPO_BRANCH=\${REPO_BRANCH:-main}
      - REDIS_URL=redis://redis:6379
      - REDIS_HOST=redis
      - ORCHESTRATOR_PORT=\${ORCHESTRATOR_PORT:-3100}
      - WORKER_COUNT=\${WORKER_COUNT:-3}
      - PROJECT_ID=proj_xyz789def
      - PROJECT_NAME=Acme Platform
      - GITHUB_TOKEN=\${GITHUB_TOKEN}
      - ANTHROPIC_API_KEY=\${ANTHROPIC_API_KEY}

    volumes:
      - workspace:/workspaces
      - claude-config:/home/node/.claude
      - \${HOME}/.claude.json:/home/node/.claude.json:ro
      - /var/run/docker.sock:/var/run/docker-host.sock

    working_dir: /workspaces

    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:\${ORCHESTRATOR_PORT:-3100}/api/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s

    depends_on:
      redis:
        condition: service_healthy

    extra_hosts:
      - "host.docker.internal:host-gateway"

    networks:
      - generacy

  # ==========================================================================
  # Workers - Parallel task execution containers (scaled)
  # ==========================================================================
  worker:
    build:
      context: .
      dockerfile: Dockerfile
    entrypoint: /usr/local/share/scripts/entrypoint-worker.sh
    user: node
    restart: unless-stopped
    stop_grace_period: 30s

    deploy:
      replicas: \${WORKER_COUNT:-3}

    env_file:
      - .env

    environment:
      - ROLE=worker
      - REPO_URL=\${REPO_URL}
      - REPO_BRANCH=\${REPO_BRANCH:-main}
      - REDIS_URL=redis://redis:6379
      - REDIS_HOST=redis
      - ORCHESTRATOR_URL=http://orchestrator:\${ORCHESTRATOR_PORT:-3100}
      - HEALTH_PORT=9001
      - PROJECT_ID=proj_xyz789def
      - GITHUB_TOKEN=\${GITHUB_TOKEN}
      - ANTHROPIC_API_KEY=\${ANTHROPIC_API_KEY}

    volumes:
      - claude-config:/home/node/.claude
      - \${HOME}/.claude.json:/home/node/.claude.json:ro

    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:9001/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 90s

    depends_on:
      redis:
        condition: service_healthy
      orchestrator:
        condition: service_healthy

    extra_hosts:
      - "host.docker.internal:host-gateway"

    networks:
      - generacy

# ============================================================================
# Networks
# ============================================================================
networks:
  generacy:
    driver: bridge
    name: proj_xyz789def-cluster-network

# ============================================================================
# Volumes
# ============================================================================
volumes:
  # Persistent workspace for cloned repos
  workspace:
    name: proj_xyz789def-workspace

  # Shared Claude config across orchestrator and workers
  claude-config:
    name: proj_xyz789def-claude-config

  # Redis data persistence
  redis-data:
    name: proj_xyz789def-redis-data
"
`;

