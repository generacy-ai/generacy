  "workspaceFolders": [
    {
      "name": "platform-orchestrator (primary)",
      "path": "/workspaces/platform-orchestrator"
    },
    {
      "name": "api-service",
      "path": "/workspaces/api-service"
    },
        {
      "name": "frontend-app",
      "path": "/workspaces/frontend-app"
    },
        {
      "name": "worker-service",
      "path": "/workspaces/worker-service"
    }
    ,
    {
      "name": "shared-lib (clone)",
      "path": "/workspaces/shared-lib"
    },
        {
      "name": "proto-definitions (clone)",
      "path": "/workspaces/proto-definitions"
    }
    
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "generacy-ai.agency",
        "generacy-ai.generacy"
      ]
    }
  }
}
"
