exports[`Snapshot: Edge Cases > should match snapshot for config.yaml with orchestrator section 1`] = `
"# .generacy/config.yaml
# Generated: 2026-02-24T16:45:30.123Z
# Schema version: 1.0.0
# Generated by: generacy-cloud
#
# This file defines your Generacy project configuration.
# Learn more: https://docs.generacy.ai/config

# ============================================================================
# Project Metadata
# ============================================================================

project:
  # Unique project identifier
  id: "proj_xyz789def"

  # Human-readable project name
  name: "Acme Platform"

# ============================================================================
# Repository Configuration
# ============================================================================

repos:
  # Primary repository (receives onboarding PR)
  primary: "acme-corp/platform-orchestrator"

  # Development repositories (Generacy can create PRs here)
  dev:
    - "acme-corp/api-service"
    - "acme-corp/frontend-app"
    - "acme-corp/worker-service"

  # Clone-only repositories (read-only access, no PRs created)
  clone:
    - "acme-corp/shared-lib"
    - "acme-corp/proto-definitions"

# ============================================================================
# Default Settings
# ============================================================================

defaults:
  # Default AI agent to use for tasks
  agent: "claude-code"

  # Default base branch for pull requests
  baseBranch: "develop"

# ============================================================================
# Orchestrator Configuration (Multi-Repo Projects)
# ============================================================================

orchestrator:
  # How often the orchestrator checks for new tasks (milliseconds)
  pollIntervalMs: 3000

  # Number of parallel worker containers to spawn
  workerCount: 3
"
`;

exports[`Snapshot: Edge Cases > should match snapshot for docker-compose.yml with multiple repos 1`] = `
"# docker-compose.yml
# Generated: 2026-02-24T16:45:30.123Z
# Schema version: 1.0.0
# Generated by: generacy-cloud
#
# Multi-repo development environment for Acme Platform
# Orchestrator + Workers architecture for parallel task execution

version: "3.8"

services:
  # ==========================================================================
  # Redis - Message queue for orchestrator/worker communication
  # ==========================================================================
  redis:
    image: redis:7-alpine
    container_name: proj_xyz789def-redis
    command: redis-server --appendonly no --save ""
    ports:
      - "6379:6379"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 5
    networks:
      - generacy

  # ==========================================================================
  # Orchestrator - Main development container with all repos mounted
  # ==========================================================================
  orchestrator:
    image: mcr.microsoft.com/devcontainers/base:ubuntu
    container_name: proj_xyz789def-orchestrator

    # Install Generacy Dev Container Feature
    features:
      ghcr.io/generacy-ai/features/generacy:1: {}

    # Load environment variables from .generacy/generacy.env
    env_file:
      - ../.generacy/generacy.env

    environment:
      # Redis connection for task queue
      - REDIS_URL=redis://redis:6379

      # Orchestrator-specific settings
      - ROLE=orchestrator
      - WORKER_COUNT=3
      - POLL_INTERVAL_MS=3000

      # Project metadata
      - PROJECT_ID=proj_xyz789def
      - PROJECT_NAME=Acme Platform
      - PRIMARY_REPO=acme-corp/platform-orchestrator

    # Mount all repositories as workspace folders
    volumes:
      # Primary repository
      - ../..:/workspaces/platform-orchestrator:cached

      # Development repositories
      - ../../api-service:/workspaces/api-service:cached
      - ../../frontend-app:/workspaces/frontend-app:cached
      - ../../worker-service:/workspaces/worker-service:cached

      # Clone-only repositories (read-only)
      - ../../shared-lib:/workspaces/shared-lib:cached
      - ../../proto-definitions:/workspaces/proto-definitions:cached

      # Generacy state and cache directories
      - generacy-state:/home/vscode/.generacy
      - vscode-server:/home/vscode/.vscode-server

    working_dir: /workspaces/platform-orchestrator

    # Keep container running
    command: sleep infinity

    healthcheck:
      test: ["CMD", "test", "-f", "/home/vscode/.generacy/ready"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 30s

    depends_on:
      redis:
        condition: service_healthy

    networks:
      - generacy

  # ==========================================================================
  # Workers - Parallel task execution containers
  # ==========================================================================
  worker:
    image: mcr.microsoft.com/devcontainers/base:ubuntu

    # Install Generacy Dev Container Feature
    features:
      ghcr.io/generacy-ai/features/generacy:1: {}

    # Load environment variables from .generacy/generacy.env
    env_file:
      - ../.generacy/generacy.env

    environment:
      # Redis connection for task queue
      - REDIS_URL=redis://redis:6379

      # Worker-specific settings
      - ROLE=worker
      - POLL_INTERVAL_MS=3000

      # Project metadata
      - PROJECT_ID=proj_xyz789def

    # Mount all repositories as workspace folders
    volumes:
      # Primary repository
      - ../..:/workspaces/platform-orchestrator:cached

      # Development repositories
      - ../../api-service:/workspaces/api-service:cached
      - ../../frontend-app:/workspaces/frontend-app:cached
      - ../../worker-service:/workspaces/worker-service:cached

      # Clone-only repositories (read-only)
      - ../../shared-lib:/workspaces/shared-lib:cached
      - ../../proto-definitions:/workspaces/proto-definitions:cached

      # Worker-specific state (isolated from orchestrator)
      - vscode-server:/home/vscode/.vscode-server

    working_dir: /workspaces/platform-orchestrator

    # Keep container running
    command: sleep infinity

    # Scale workers based on configuration
    deploy:
      replicas: 3

    depends_on:
      redis:
        condition: service_healthy
      orchestrator:
        condition: service_healthy

    networks:
      - generacy

# ============================================================================
# Networks
# ============================================================================
networks:
  generacy:
    driver: bridge
    name: proj_xyz789def-network

# ============================================================================
# Volumes
# ============================================================================
volumes:
  # Orchestrator state (task history, logs, cache)
  generacy-state:
    name: proj_xyz789def-state

  # VS Code Server extensions and settings
  vscode-server:
    name: proj_xyz789def-vscode-server
"
`;

