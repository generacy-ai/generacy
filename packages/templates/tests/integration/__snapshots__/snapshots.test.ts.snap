exports[`Snapshot: Multi-Repo Templates > should match snapshot for generacy.env.template (multi-repo) 1`] = `
"# .generacy/generacy.env.template
#
# This is a TEMPLATE file. Copy it to \`generacy.env\` and fill in your actual values.
# The \`generacy.env\` file contains secrets and is automatically ignored by git.
#
# DO NOT commit \`generacy.env\` to version control!
# DO NOT share \`generacy.env\` in public channels!
#
# Generated: 2026-02-24T16:45:30.123Z
# Generated by: generacy-cloud

# ============================================================================
# GitHub Integration
# ============================================================================

# GitHub Personal Access Token (PAT) with repo permissions
# Required for: Creating PRs, reading repositories, managing issues
# Get one at: https://github.com/settings/tokens/new
# Minimum scopes: repo, workflow (for Actions integration)
#
# SECURITY: Store securely, never commit to git, rotate regularly
GITHUB_TOKEN=

# ============================================================================
# AI Agent Configuration
# ============================================================================

# Anthropic API key for Claude Code agent
# Required for: Running AI-powered development tasks
# Get one at: https://console.anthropic.com/settings/keys
#
# SECURITY: Store securely, never commit to git
ANTHROPIC_API_KEY=

# ============================================================================
# Project Configuration
# ============================================================================

# Your Generacy project ID (auto-populated from config.yaml)
# This links your local environment to your Generacy cloud project
PROJECT_ID=proj_xyz789def

# ============================================================================
# Local Development Configuration
# ============================================================================

# Redis URL for task queue (multi-repo orchestration)
# Default points to local Redis instance in dev container
# Override for custom Redis setup or external Redis instance
REDIS_URL=redis://redis:6379

# Logging level for Generacy agent output
# Options: debug, info, warn, error
# Default: info (recommended for development)
LOG_LEVEL=info

# ============================================================================
# Optional: Advanced Configuration
# ============================================================================

# Uncomment and configure these if you need custom behavior:

# Base branch for pull requests (overrides config.yaml default)
# BASE_BRANCH=develop

# API endpoint for Generacy cloud service (for self-hosted deployments)
# GENERACY_API_URL=https://api.generacy.ai

# Custom agent configuration (overrides config.yaml default)
# AGENT=claude-code

# GitHub API base URL (for GitHub Enterprise)
# GITHUB_API_URL=https://api.github.com

# ============================================================================
# Multi-Repo Orchestration (Multi-Repo Projects Only)
# ============================================================================

# Poll interval for orchestrator task queue (milliseconds)
# How often workers check for new tasks
# Default: 3000ms (configured in config.yaml)
# POLL_INTERVAL_MS=3000

# Worker timeout for long-running tasks (seconds)
# Adjust if your tasks typically take longer than 30 minutes
# WORKER_TIMEOUT_SECONDS=1800
"
`;

