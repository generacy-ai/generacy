# docker-compose.yml
# Generated: {{metadata.timestamp}}
# Schema version: {{metadata.version}}
# Generated by: {{metadata.generatedBy}}
#
# Multi-repo development environment for {{project.name}}
# Orchestrator + Workers architecture for parallel task execution

services:
  # ==========================================================================
  # Redis - Message queue for orchestrator/worker communication
  # ==========================================================================
  redis:
    image: redis:7-alpine
    container_name: {{project.id}}-redis
    command: redis-server --appendonly no --save ""
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 5
    networks:
      - generacy

  # ==========================================================================
  # Orchestrator - Main development container with all repos mounted
  # ==========================================================================
  orchestrator:
    image: {{devcontainer.baseImage}}
    container_name: {{project.id}}-orchestrator

    # Load environment variables from .generacy/generacy.env
    env_file:
      - ../.generacy/generacy.env

    environment:
      # Redis connection for task queue
      - REDIS_URL=redis://redis:6379

      # Orchestrator-specific settings
      - ROLE=orchestrator
      - WORKER_COUNT={{orchestrator.workerCount}}
      - POLL_INTERVAL_MS={{orchestrator.pollIntervalMs}}

      # Project metadata
      - PROJECT_ID={{project.id}}
      - PROJECT_NAME={{project.name}}
      - PRIMARY_REPO={{repos.primary}}

    # Mount all repositories as workspace folders
    volumes:
      # Primary repository
      - ..:/workspaces/{{repoName repos.primary}}:cached
      {{#if repos.hasDevRepos}}

      # Development repositories
      {{#each repos.dev}}
      - ../../{{repoName this}}:/workspaces/{{repoName this}}:cached
      {{/each}}
      {{/if}}
      {{#if repos.hasCloneRepos}}

      # Clone-only repositories (read-only)
      {{#each repos.clone}}
      - ../../{{repoName this}}:/workspaces/{{repoName this}}:cached
      {{/each}}
      {{/if}}

      # Generacy state and cache directories
      - generacy-state:/home/vscode/.generacy
      - vscode-server:/home/vscode/.vscode-server

    working_dir: /workspaces/{{repoName repos.primary}}

    # Keep container running
    command: sleep infinity

    healthcheck:
      test: ["CMD", "test", "-f", "/home/vscode/.generacy/ready"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 30s

    depends_on:
      redis:
        condition: service_healthy

    networks:
      - generacy

  # ==========================================================================
  # Workers - Parallel task execution containers
  # ==========================================================================
  worker:
    image: {{devcontainer.baseImage}}

    # Load environment variables from .generacy/generacy.env
    env_file:
      - ../.generacy/generacy.env

    environment:
      # Redis connection for task queue
      - REDIS_URL=redis://redis:6379

      # Worker-specific settings
      - ROLE=worker
      - POLL_INTERVAL_MS={{orchestrator.pollIntervalMs}}

      # Project metadata
      - PROJECT_ID={{project.id}}

    # Mount all repositories as workspace folders
    volumes:
      # Primary repository
      - ..:/workspaces/{{repoName repos.primary}}:cached
      {{#if repos.hasDevRepos}}

      # Development repositories
      {{#each repos.dev}}
      - ../../{{repoName this}}:/workspaces/{{repoName this}}:cached
      {{/each}}
      {{/if}}
      {{#if repos.hasCloneRepos}}

      # Clone-only repositories (read-only)
      {{#each repos.clone}}
      - ../../{{repoName this}}:/workspaces/{{repoName this}}:cached
      {{/each}}
      {{/if}}

    working_dir: /workspaces/{{repoName repos.primary}}

    # Keep container running
    command: sleep infinity

    healthcheck:
      test: ["CMD", "test", "-f", "/home/vscode/.generacy/ready"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 30s

    # Scale workers based on configuration
    deploy:
      replicas: {{orchestrator.workerCount}}

    depends_on:
      redis:
        condition: service_healthy
      orchestrator:
        condition: service_healthy

    networks:
      - generacy

# ============================================================================
# Networks
# ============================================================================
networks:
  generacy:
    driver: bridge
    name: {{project.id}}-network

# ============================================================================
# Volumes
# ============================================================================
volumes:
  # Orchestrator state (task history, logs, cache)
  generacy-state:
    name: {{project.id}}-state

  # VS Code Server extensions and settings
  vscode-server:
    name: {{project.id}}-vscode-server
