{
  "name": "{{project.name}}",
  "dockerComposeFile": "docker-compose.yml",
  "service": "orchestrator",
  "workspaceFolder": "/workspaces/{{repoName repos.primary}}",
  "workspaceFolders": [
    {
      "name": "{{repoName repos.primary}} (primary)",
      "path": "/workspaces/{{repoName repos.primary}}"
    }{{#if repos.hasDevRepos}},
    {{#each repos.dev}}
    {
      "name": "{{repoName this}}",
      "path": "/workspaces/{{repoName this}}"
    }{{#unless @last}},{{/unless}}
    {{/each}}{{/if}}{{#if repos.hasCloneRepos}},
    {{#each repos.clone}}
    {
      "name": "{{repoName this}} (clone)",
      "path": "/workspaces/{{repoName this}}"
    }{{#unless @last}},{{/unless}}
    {{/each}}{{/if}}
  ],
  "features": {
    "ghcr.io/generacy-ai/generacy/generacy{{devcontainer.featureTag}}": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "generacy-ai.agency",
        "generacy-ai.generacy"
      ]
    }
  }
}
