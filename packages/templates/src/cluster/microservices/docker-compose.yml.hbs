# docker-compose.yml
# Generated: {{metadata.timestamp}}
# Schema version: {{metadata.version}}
# Generated by: {{metadata.generatedBy}}
#
# Microservices cluster (DinD) for {{project.name}}
# Orchestrator + Workers + Redis — Docker-in-Docker (privileged)

services:
  # ==========================================================================
  # Redis - Message queue for orchestrator/worker communication
  # ==========================================================================
  redis:
    image: redis:7-alpine
    command: redis-server --appendonly no --save ""
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 5
      start_period: 5s
    volumes:
      - redis-data:/data
    networks:
      - generacy
    restart: unless-stopped

  # ==========================================================================
  # Orchestrator - Main development container
  # ==========================================================================
  orchestrator:
    build:
      context: .
      dockerfile: Dockerfile
    entrypoint: /usr/local/share/scripts/entrypoint-orchestrator.sh
    user: node
    restart: unless-stopped
    stop_grace_period: 30s

    ports:
      - "${ORCHESTRATOR_PORT:-3100}:${ORCHESTRATOR_PORT:-3100}"

    env_file:
      - .env

    environment:
      - ROLE=orchestrator
      - REPO_URL=${REPO_URL}
      - REPO_BRANCH=${REPO_BRANCH:-main}
      - REDIS_URL=redis://redis:6379
      - REDIS_HOST=redis
      - ORCHESTRATOR_PORT=${ORCHESTRATOR_PORT:-3100}
      - WORKER_COUNT=${WORKER_COUNT:-3}
      - PROJECT_ID={{project.id}}
      - PROJECT_NAME={{project.name}}
      - GITHUB_TOKEN=${GITHUB_TOKEN}
      - ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}

    volumes:
      - workspace:/workspaces
      - claude-config:/home/node/.claude
      - ${HOME}/.claude.json:/home/node/.claude.json:ro
      - /var/run/docker.sock:/var/run/docker-host.sock

    working_dir: /workspaces

    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:${ORCHESTRATOR_PORT:-3100}/api/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s

    depends_on:
      redis:
        condition: service_healthy

    extra_hosts:
      - "host.docker.internal:host-gateway"

    networks:
      - generacy

  # ==========================================================================
  # Workers - Parallel task execution containers (scaled, privileged for DinD)
  # ==========================================================================
  worker:
    build:
      context: .
      dockerfile: Dockerfile
    entrypoint: /usr/local/share/scripts/entrypoint-worker.sh
    user: node
    privileged: true
    restart: unless-stopped
    stop_grace_period: 30s

    deploy:
      replicas: ${WORKER_COUNT:-3}

    env_file:
      - .env

    environment:
      - ROLE=worker
      - REPO_URL=${REPO_URL}
      - REPO_BRANCH=${REPO_BRANCH:-main}
      - REDIS_URL=redis://redis:6379
      - REDIS_HOST=redis
      - ORCHESTRATOR_URL=http://orchestrator:${ORCHESTRATOR_PORT:-3100}
      - HEALTH_PORT=9001
      - PROJECT_ID={{project.id}}
      - GITHUB_TOKEN=${GITHUB_TOKEN}
      - ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
      - ENABLE_DIND=true

    volumes:
      - claude-config:/home/node/.claude
      - ${HOME}/.claude.json:/home/node/.claude.json:ro

    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:9001/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 90s

    depends_on:
      redis:
        condition: service_healthy
      orchestrator:
        condition: service_healthy

    extra_hosts:
      - "host.docker.internal:host-gateway"

    networks:
      - generacy

# ============================================================================
# Networks
# ============================================================================
networks:
  generacy:
    driver: bridge
    name: {{project.id}}-cluster-network

# ============================================================================
# Volumes
# ============================================================================
volumes:
  # Persistent workspace for cloned repos
  workspace:
    name: {{project.id}}-workspace

  # Shared Claude config across orchestrator and workers
  claude-config:
    name: {{project.id}}-claude-config

  # Redis data persistence
  redis-data:
    name: {{project.id}}-redis-data
