// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`ClaudeCodeLaunchPlugin > buildLaunch snapshots > conversation-turn intent > snapshot: all flags (sessionId + skipPermissions + model) 1`] = `
{
  "args": [
    "-u",
    "-c",
    "import pty, os, sys
# Prevent PTY line wrapping by setting huge terminal width
os.environ["COLUMNS"] = "50000"
def read(fd):
    data = os.read(fd, 65536)
    # Strip CRLF that PTY adds, return cleaned data
    # (pty._copy writes our return value to stdout)
    return data.replace(b"\\r\\n", b"\\n")
pty.spawn(sys.argv[1:], read)",
    "claude",
    "-p",
    "Hello Claude",
    "--output-format",
    "stream-json",
    "--verbose",
    "--resume",
    "session-xyz",
    "--dangerously-skip-permissions",
    "--model",
    "claude-opus-4-6",
  ],
  "command": "python3",
  "stdioProfile": "interactive",
}
`;

