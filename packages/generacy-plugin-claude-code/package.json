{
  "name": "@generacy-ai/generacy-plugin-claude-code",
  "version": "0.1.0",
  "description": "Claude Code agent platform plugin for Generacy - invokes Claude Code agents in isolated Docker containers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@generacy-ai/latency": "workspace:*",
    "@generacy-ai/latency-plugin-dev-agent": "workspace:*",
    "dockerode": "^4.0.0",
    "pino": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0",
    "tsx": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "claude-code",
    "agent",
    "plugin",
    "docker",
    "generacy"
  ],
  "license": "MIT"
}
