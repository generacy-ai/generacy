{
  "name": "@generacy-ai/workflow-engine",
  "version": "0.1.0",
  "description": "Workflow execution engine for Generacy - shared between CLI and VS Code extension",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "workflow",
    "engine",
    "generacy",
    "automation"
  ],
  "author": "Generacy AI",
  "license": "MIT",
  "dependencies": {
    "uuid": "^9.0.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@octokit/rest": "^20.0.0 || ^21.0.0"
  },
  "peerDependenciesMeta": {
    "@octokit/rest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.19.30",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "simple-git": "^3.30.0",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/generacy-ai/generacy.git",
    "directory": "packages/workflow-engine"
  },
  "publishConfig": {
    "access": "public"
  }
}
