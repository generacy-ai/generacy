{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://generacy.ai/schemas/cluster-json.v2.json",
  "title": "ClusterIdentity",
  "description": "On-disk cluster identity at .generacy/cluster.json. Snake-case for parity with cloud LaunchConfig.",
  "type": "object",
  "additionalProperties": false,
  "required": ["cluster_id", "project_id", "org_id", "cloud_url"],
  "properties": {
    "cluster_id": {
      "type": "string",
      "description": "Cloud-minted UUID. May be empty string before activation completes.",
      "minLength": 0
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "org_id": {
      "type": "string",
      "minLength": 1
    },
    "cloud_url": {
      "type": "string",
      "format": "uri"
    },
    "display_name": {
      "type": "string",
      "description": "Normalized cluster display name. Immutable after creation.",
      "pattern": "^[a-z][a-z0-9-]{0,62}$"
    },
    "activated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
