{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://generacy.ai/schemas/cluster-metadata.v2.json",
  "title": "ClusterMetadata",
  "description": "Relay-channel metadata sent on handshake and periodic metadata pushes. Additive — receivers tolerating extra fields are unaffected.",
  "type": "object",
  "required": ["workers", "activeWorkflows", "channel", "orchestratorVersion", "gitRemotes", "uptime"],
  "properties": {
    "workers": { "type": "integer", "minimum": 0 },
    "activeWorkflows": { "type": "integer", "minimum": 0 },
    "channel": { "type": "string", "enum": ["preview", "stable"] },
    "orchestratorVersion": { "type": "string" },
    "gitRemotes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "url"],
        "properties": {
          "name": { "type": "string" },
          "url": { "type": "string" }
        }
      }
    },
    "uptime": { "type": "number", "minimum": 0 },
    "codeServerReady": { "type": "boolean" },
    "controlPlaneReady": { "type": "boolean" },
    "displayName": {
      "type": "string",
      "description": "User-facing cluster display name. Decoupled from tunnel name.",
      "pattern": "^[a-z][a-z0-9-]{0,62}$"
    },
    "clusterId": {
      "type": "string",
      "description": "Cluster UUID. Explicit field for #792 cloud rendering — previously inferred from handshake."
    }
  }
}
