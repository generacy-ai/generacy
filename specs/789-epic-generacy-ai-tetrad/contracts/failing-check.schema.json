{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://generacy.ai/schemas/cockpit/failing-check.json",
  "title": "FailingCheckPayload",
  "description": "JSON written to stdout by `generacy cockpit merge <issue>` on any red outcome (Q2).",
  "type": "object",
  "required": ["status", "reason", "pr", "failingChecks"],
  "properties": {
    "status": {
      "type": "string",
      "const": "red",
      "description": "Always the literal 'red' — the green path emits no stdout."
    },
    "reason": {
      "type": "string",
      "enum": ["checks-failing", "missing-label", "unresolved", "pr-is-draft", "ambiguous-resolution"],
      "description": "Discriminator. Routes the consumer to the right next action (fixer, label, fail-loud)."
    },
    "pr": {
      "description": "PR identifiers. Null when reason='unresolved' AND the issue had no associated PR, or for multi-candidate reasons (pr-is-draft, ambiguous-resolution) where the PR set lives on `candidates` instead.",
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["number", "url"],
          "additionalProperties": false,
          "properties": {
            "number": { "type": "integer", "minimum": 1 },
            "url":    { "type": "string", "format": "uri" }
          }
        },
        {
          "type": "object",
          "required": ["number", "url", "linkMethod"],
          "additionalProperties": false,
          "properties": {
            "number":     { "type": "integer", "minimum": 1 },
            "url":        { "type": "string", "format": "uri" },
            "linkMethod": { "type": "string", "enum": ["closing-refs", "branch-name", "pr-body"] }
          }
        }
      ]
    },
    "linkMethod": {
      "type": "string",
      "enum": ["closing-refs", "branch-name", "pr-body"],
      "description": "Present only when reason ∈ { pr-is-draft, ambiguous-resolution }."
    },
    "candidates": {
      "type": "array",
      "description": "Present only when reason ∈ { pr-is-draft, ambiguous-resolution }.",
      "items": {
        "type": "object",
        "required": ["number", "url", "isDraft", "headRefName"],
        "additionalProperties": false,
        "properties": {
          "number":      { "type": "integer", "minimum": 1 },
          "url":         { "type": "string", "format": "uri" },
          "isDraft":     { "type": "boolean" },
          "headRefName": { "type": "string", "minLength": 1 }
        }
      }
    },
    "failingChecks": {
      "type": "array",
      "description": "Non-empty iff reason='checks-failing'. Empty for the other reasons.",
      "items": {
        "type": "object",
        "required": ["name", "state"],
        "additionalProperties": false,
        "properties": {
          "name":  { "type": "string", "minLength": 1 },
          "state": {
            "type": "string",
            "enum": ["FAILURE", "PENDING", "NEUTRAL", "SKIPPED", "CANCELLED", "MISSING"],
            "description": "'MISSING' = check is required by branch protection but absent from the PR's check list."
          },
          "url":   { "type": "string", "format": "uri" }
        }
      }
    },
    "issue": { "$ref": "#/$defs/IssueRefWithState" }
  },
  "$defs": {
    "IssueRefWithState": {
      "type": "object",
      "required": ["owner", "repo", "number"],
      "additionalProperties": false,
      "properties": {
        "owner":  { "type": "string", "minLength": 1 },
        "repo":   { "type": "string", "minLength": 1 },
        "number": { "type": "integer", "minimum": 1 },
        "state":       { "type": "string", "enum": ["OPEN", "CLOSED"] },
        "stateReason": { "type": ["string", "null"] }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "reason": { "const": "checks-failing" } } },
      "then": {
        "properties": {
          "pr": { "type": "object" },
          "failingChecks": { "minItems": 1 }
        }
      }
    },
    {
      "if": { "properties": { "reason": { "const": "missing-label" } } },
      "then": {
        "properties": {
          "pr": { "type": "object" },
          "failingChecks": { "maxItems": 0 }
        }
      }
    },
    {
      "if": { "properties": { "reason": { "const": "unresolved" } } },
      "then": {
        "properties": {
          "failingChecks": { "maxItems": 0 }
        }
      }
    },
    {
      "if": { "properties": { "reason": { "const": "pr-is-draft" } } },
      "then": {
        "required": ["candidates", "linkMethod"],
        "properties": {
          "pr":         { "type": "null" },
          "candidates": { "minItems": 1, "items": { "properties": { "isDraft": { "const": true } } } },
          "failingChecks": { "maxItems": 0 }
        }
      }
    },
    {
      "if": { "properties": { "reason": { "const": "ambiguous-resolution" } } },
      "then": {
        "required": ["candidates", "linkMethod"],
        "properties": {
          "pr":         { "type": "null" },
          "candidates": { "minItems": 2, "items": { "properties": { "isDraft": { "const": false } } } },
          "failingChecks": { "maxItems": 0 }
        }
      }
    }
  ]
}
