{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://generacy.ai/contracts/cluster-credentials-event.schema.json",
  "title": "ClusterCredentialsEvent",
  "description": "Discriminated payload emitted by the orchestrator on the `cluster.credentials` relay channel for GitHub App credential health and refresh signaling. Issue #762.",
  "type": "object",
  "required": ["action", "credentialId", "type"],
  "oneOf": [
    {
      "title": "RefreshRequested",
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "credentialId", "type"],
      "properties": {
        "action": { "const": "refresh-requested" },
        "credentialId": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9_-]+$" },
        "type": { "const": "github-app" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "reason": {
          "type": "string",
          "description": "Why the cluster is asking for a refresh. Recognized values: `near-expiry` (proactive 60s timer hit threshold), `auth-401` (a monitor observed HTTP 401)."
        }
      }
    },
    {
      "title": "AuthFailed",
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "credentialId", "type", "consecutiveFailures"],
      "properties": {
        "action": { "const": "auth-failed" },
        "credentialId": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9_-]+$" },
        "type": { "const": "github-app" },
        "consecutiveFailures": { "type": "integer", "minimum": 1 },
        "reason": { "type": "string" }
      }
    },
    {
      "title": "AuthRecovered",
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "credentialId", "type", "recoveredAfterFailures"],
      "properties": {
        "action": { "const": "auth-recovered" },
        "credentialId": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9_-]+$" },
        "type": { "const": "github-app" },
        "recoveredAfterFailures": { "type": "integer", "minimum": 1 }
      }
    }
  ],
  "examples": [
    {
      "action": "refresh-requested",
      "credentialId": "primary-github-app",
      "type": "github-app",
      "expiresAt": "2026-06-05T03:14:00.000Z",
      "reason": "near-expiry"
    },
    {
      "action": "auth-failed",
      "credentialId": "primary-github-app",
      "type": "github-app",
      "consecutiveFailures": 3,
      "reason": "HTTP 401: Bad credentials"
    },
    {
      "action": "auth-recovered",
      "credentialId": "primary-github-app",
      "type": "github-app",
      "recoveredAfterFailures": 5
    }
  ]
}
