{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://generacy.ai/schemas/cockpit-gates/gate-record.json",
  "title": "GateRecord",
  "description": "Presenter-agnostic gate-open payload emitted by a driving /cockpit:auto session. Mirrored by generacy-cloud from packages/cockpit/src/gates/schemas.ts (source of truth).",
  "type": "object",
  "required": [
    "gateId",
    "gateKey",
    "gateType",
    "epicRef",
    "issueRef",
    "issueTitle",
    "issueUrl",
    "title",
    "body",
    "options",
    "allowFreeText",
    "sessionId",
    "askedAt"
  ],
  "properties": {
    "gateId": {
      "type": "string",
      "pattern": "^[0-9a-f]{24}$",
      "description": "First 24 hex chars of sha256(gateKey). Deterministic; load-bearing for restart/takeover idempotency."
    },
    "gateKey": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable pre-image, format `<owner>/<repo>#<issue>:<gateType>:<generation>`. Never parsed back — only hashed."
    },
    "gateType": {
      "type": "string",
      "enum": [
        "clarification",
        "artifact-review",
        "implementation-review",
        "manual-validation",
        "escalation",
        "phase-queue",
        "filing",
        "scope-drained"
      ]
    },
    "epicRef": { "$ref": "#/$defs/IssueRef" },
    "issueRef": { "$ref": "#/$defs/IssueRef" },
    "issueTitle": { "type": "string", "minLength": 1 },
    "issueUrl": { "type": "string", "format": "uri" },
    "branch": { "type": "string", "minLength": 1 },
    "prNumber": { "type": "integer", "exclusiveMinimum": 0 },
    "title": { "type": "string", "minLength": 1 },
    "body": {
      "type": "string",
      "description": "Markdown body; empty string is allowed for pure-options gates."
    },
    "options": {
      "type": "array",
      "minItems": 0,
      "items": { "$ref": "#/$defs/GateOption" }
    },
    "allowFreeText": {
      "const": true,
      "description": "Schema invariant per clarifications Q4 — every gate keeps an 'Other'-style escape hatch."
    },
    "sessionId": { "type": "string", "minLength": 1 },
    "askedAt": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "IssueRef": {
      "type": "object",
      "required": ["owner", "repo", "number"],
      "properties": {
        "owner": { "type": "string", "pattern": "^[a-zA-Z0-9-_.]+$" },
        "repo": { "type": "string", "pattern": "^[a-zA-Z0-9-_.]+$" },
        "number": { "type": "integer", "exclusiveMinimum": 0 }
      }
    },
    "GateOption": {
      "type": "object",
      "required": ["id", "label", "description"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "Required (Q3=A); the inbox UI can always render per-option help without a fallback."
        },
        "recommended": {
          "type": "boolean",
          "description": "Optional; no default coercion (Q3=A) — undefined means not recommended."
        }
      }
    }
  }
}
