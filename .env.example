# =============================================================================
# Generacy — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your deployment.
# See: docs/docs/reference/config/environment-variables.md

# =============================================================================
# Authentication
# =============================================================================

# API key for authenticating requests to the orchestrator
API_KEY=your-api-key-here

# Authentication token for the orchestrator (enables auth when set)
# ORCHESTRATOR_TOKEN=

# GitHub Personal Access Token — required for repo access and PR creation
# Minimum scopes: repo, workflow
GITHUB_TOKEN=your-github-token

# =============================================================================
# Redis
# =============================================================================

# Redis connection URL (used by orchestrator and workers)
REDIS_URL=redis://localhost:6379

# =============================================================================
# Orchestrator — Server
# =============================================================================

# Port the orchestrator listens on
ORCHESTRATOR_PORT=3000

# Host the orchestrator binds to
# ORCHESTRATOR_HOST=0.0.0.0

# =============================================================================
# Orchestrator — Label Monitor
# =============================================================================

# Comma-separated owner/repo list to monitor for label changes
# MONITORED_REPOS=myorg/repo-a,myorg/repo-b

# GitHub webhook secret for signature verification
# WEBHOOK_SECRET=

# Label monitor poll interval in milliseconds (min 5000)
# POLL_INTERVAL_MS=30000

# =============================================================================
# Worker
# =============================================================================

# URL of the orchestrator that workers connect to
# ORCHESTRATOR_URL=http://localhost:3000

# Number of concurrent jobs a worker can process
WORKER_CONCURRENCY=2

# =============================================================================
# Logging
# =============================================================================

# Log level: trace, debug, info, warn, error
LOG_LEVEL=info
